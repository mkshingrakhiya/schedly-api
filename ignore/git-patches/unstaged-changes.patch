+
+    /**
+     * @param  array{email: string, password: string}  $validated
+     */
+    public function loginUser(array $validated): ?User
+    {
+        $data = LoginUserDataDTO::fromArray($validated);
+
+        if (! Auth::attempt([
+            'email' => $data->email,
+            'password' => $data->password,
+        ])) {
+            return null;
+        }
+
+        $user = Auth::user();
+
+        return $user instanceof User ? $user : null;
+    }
 }
